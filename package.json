{
  "name": "kaso",
  "version": "0.1.0",
  "description": "Kiro-Enabled Agent Swarm Orchestrator - locally-run modular orchestration system for AI-assisted engineering",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:property": "vitest run --reporter=verbose tests/**/*property*.test.ts",
    "test:integration": "vitest run tests/**/*integration*.test.ts",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "ai",
    "orchestration",
    "kaso",
    "kiro",
    "automation"
  ],
  "author": "Nikolay Butnik",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "chokidar": "^3.5.3",
    "commander": "^11.1.0",
    "keytar": "^7.9.0",
    "simple-git": "^3.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.1.6",
    "@types/node": "^20.10.6",
    "@vitest/coverage-v8": "^1.1.0",
    "playwright": "^1.40.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
