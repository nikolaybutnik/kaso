{
  "name": "kaso",
  "version": "0.2.0",
  "description": "Kiro-Enabled Agent Swarm Orchestrator - locally-run modular orchestration system for AI-assisted engineering",
  "main": "dist/index.js",
  "bin": {
    "kaso": "dist/kaso.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/cli/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/kaso.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:property": "vitest run --reporter=verbose tests/**/*property*.test.ts",
    "test:integration": "vitest run tests/**/*integration*.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e/tier1-*.e2e.test.ts tests/e2e/tier2-*.e2e.test.ts tests/e2e/tier3-*.e2e.test.ts tests/e2e/tier4-*.e2e.test.ts",
    "test:e2e:tier1": "vitest run --testTimeout=60000 tests/e2e/tier1-*.e2e.test.ts",
    "test:e2e:tier2": "vitest run --testTimeout=120000 tests/e2e/tier2-*.e2e.test.ts",
    "test:e2e:tier3": "vitest run --testTimeout=180000 tests/e2e/tier3-*.e2e.test.ts",
    "test:e2e:tier4": "vitest run --testTimeout=300000 tests/e2e/tier4-*.e2e.test.ts"
  },
  "keywords": [
    "ai",
    "orchestration",
    "kaso",
    "kiro",
    "automation"
  ],
  "author": "Nikolay Butnik",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "chokidar": "^3.5.3",
    "commander": "^11.1.0",
    "dotenv": "^16.6.1",
    "keytar": "^7.9.0",
    "simple-git": "^3.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.1.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.6",
    "@vitest/coverage-v8": "^1.1.0",
    "esbuild": "^0.27.4",
    "playwright": "^1.40.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
