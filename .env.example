# =============================================================================
# KASO Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# KASO loads secrets from two sources (in priority order):
#   1. Environment variables (including .env)
#   2. OS keychain via keytar (fallback)
#
# To store a key in the OS keychain instead of .env:
#   keytar setPassword "kaso" "KIMI_API_KEY" "<your-key>"
#
# All secret values are automatically redacted from logs by the LogRedactor.
# Never commit .env to version control — it's already in .gitignore.
#
# =============================================================================


# =============================================================================
# AI Backend API Keys
# =============================================================================

# [REQUIRED] Kimi Code API key
# Used by the default "kimi-code" executor backend for code generation,
# review council reviews, and all AI-powered pipeline phases.
# Get yours at: https://platform.moonshot.cn/
KIMI_API_KEY=

# [OPTIONAL] Anthropic API key
# Used when "claude-code" backend is configured in kaso.config.json,
# or as an alternative backend during retry escalation (default → reduced
# context → alternative backend).
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# [OPTIONAL] OpenAI API key
# Used when a Codex/OpenAI backend is configured in kaso.config.json,
# or as an alternative backend during retry escalation.
# Get yours at: https://platform.openai.com/
OPENAI_API_KEY=


# =============================================================================
# Webhook Security
# =============================================================================

# [OPTIONAL] HMAC-SHA256 secret for signing webhook payloads
# When set, the WebhookDispatcher signs every outgoing payload and sends
# the signature in the X-KASO-Signature header (format: sha256=<hex>).
# Your webhook receiver can verify authenticity using this shared secret.
# Use a long random string (e.g. openssl rand -hex 32).
KASO_WEBHOOK_SECRET=

# =============================================================================
# SSE Server Authentication
# =============================================================================

# [OPTIONAL] Bearer token for the SSE streaming server
# When the SSE server is enabled (sse.enabled=true in kaso.config.json),
# clients must send this token in the Authorization header:
#   Authorization: Bearer <token>
# If not set and SSE is enabled, the server runs without authentication
# (not recommended for non-localhost deployments).
# Use a long random string (e.g. openssl rand -hex 32).
KASO_SSE_AUTH_TOKEN=


# =============================================================================
# CLI / Display
# =============================================================================

# [OPTIONAL] Disable colored CLI output
# Set to "1" to suppress ANSI color codes in terminal output.
# Automatically respected by the CLI's supportsColor() check.
# Also settable via the --no-color CLI flag.
NO_COLOR=
